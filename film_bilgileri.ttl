@prefix : <http://example.org/movie/> .
@prefix ns1: <http://example.org/movie/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/movie/> .

<http://example.org/movie/> rdf:type owl:Ontology ;
                             rdfs:comment "Film ve yönetmen/tür ilişkilerini içeren kapsamlı bir film bilgi grafiği." ;
                             rdfs:label "FilmBilgiGrafigi" .

#################################################################
#    Annotation properties
#################################################################

###  http://example.org/movie/actedIn
ns1:actedIn rdf:type owl:AnnotationProperty .


###  http://example.org/movie/directedBy
ns1:directedBy rdf:type owl:AnnotationProperty .


###  http://example.org/movie/hasGenre
ns1:hasGenre rdf:type owl:AnnotationProperty .


###  http://example.org/movie/releaseDate
ns1:releaseDate rdf:type owl:AnnotationProperty .


###  http://example.org/movie/title
ns1:title rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#actedIn
<http://www.co-ode.org/ontologies/ont.owl#actedIn> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain ns1:Actor ;
                                                   rdfs:range ns1:Film .


###  http://www.co-ode.org/ontologies/ont.owl#directedBy
<http://www.co-ode.org/ontologies/ont.owl#directedBy> rdf:type owl:ObjectProperty ;
                                                      rdfs:domain ns1:Film ;
                                                      rdfs:range ns1:Director .


#################################################################
#    Data properties
#################################################################

###  http://www.co-ode.org/ontologies/ont.owl#releaseYear
<http://www.co-ode.org/ontologies/ont.owl#releaseYear> rdf:type owl:DatatypeProperty ;
                                                       rdfs:domain ns1:Film ;
                                                       rdfs:range xsd:integer .


###  http://www.co-ode.org/ontologies/ont.owl#title
<http://www.co-ode.org/ontologies/ont.owl#title> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain ns1:Film ;
                                                 rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://example.org/movie/Actor
ns1:Actor rdf:type owl:Class ;
          rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Person> .


###  http://example.org/movie/Director
ns1:Director rdf:type owl:Class ;
             rdfs:subClassOf <http://www.co-ode.org/ontologies/ont.owl#Person> .


###  http://example.org/movie/Film
ns1:Film rdf:type owl:Class .


###  http://example.org/movie/Genre
ns1:Genre rdf:type owl:Class .


###  http://www.co-ode.org/ontologies/ont.owl#Person
<http://www.co-ode.org/ontologies/ont.owl#Person> rdf:type owl:Class .


#################################################################
