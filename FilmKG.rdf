    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/movie/Actor -->

    <owl:Class rdf:about="http://example.org/movie/Actor">
        <rdfs:subClassOf rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Person"/>
    </owl:Class>
    


    <!-- http://example.org/movie/Director -->

    <owl:Class rdf:about="http://example.org/movie/Director">
        <rdfs:subClassOf rdf:resource="http://www.co-ode.org/ontologies/ont.owl#Person"/>
    </owl:Class>
    


    <!-- http://example.org/movie/Film -->

    <owl:Class rdf:about="http://example.org/movie/Film">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://example.org/movie/Genre -->

    <owl:Class rdf:about="http://example.org/movie/Genre">
