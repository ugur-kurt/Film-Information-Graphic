<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/movie/"
     xml:base="http://example.org/movie/"
     xmlns:ns1="http://example.org/movie/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://example.org/movie/"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/movie/actedIn -->

    <owl:AnnotationProperty rdf:about="http://example.org/movie/actedIn"/>
    


    <!-- http://example.org/movie/directedBy -->

    <owl:AnnotationProperty rdf:about="http://example.org/movie/directedBy"/>
    


    <!-- http://example.org/movie/hasGenre -->

    <owl:AnnotationProperty rdf:about="http://example.org/movie/hasGenre"/>
    


    <!-- http://example.org/movie/releaseDate -->

    <owl:AnnotationProperty rdf:about="http://example.org/movie/releaseDate"/>
    


    <!-- http://example.org/movie/title -->

    <owl:AnnotationProperty rdf:about="http://example.org/movie/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.co-ode.org/ontologies/ont.owl#actedIn -->

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#actedIn">
        <rdfs:domain rdf:resource="http://example.org/movie/Actor"/>
        <rdfs:range rdf:resource="http://example.org/movie/Film"/>
    </owl:ObjectProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#directedBy -->

    <owl:ObjectProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#directedBy">
        <rdfs:domain rdf:resource="http://example.org/movie/Film"/>
        <rdfs:range rdf:resource="http://example.org/movie/Director"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.co-ode.org/ontologies/ont.owl#releaseYear -->

    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#releaseYear">
        <rdfs:domain rdf:resource="http://example.org/movie/Film"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.co-ode.org/ontologies/ont.owl#title -->

    <owl:DatatypeProperty rdf:about="http://www.co-ode.org/ontologies/ont.owl#title">
        <rdfs:domain rdf:resource="http://example.org/movie/Film"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


